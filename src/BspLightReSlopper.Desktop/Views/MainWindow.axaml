<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BspLightReSlopper.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="BspLightReSlopper.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="BspLightReSlopper"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Toolbar -->
    <Grid Grid.Row="0" Background="#1e1e1e" Height="48">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="BspLightReSlopper" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#e0e0e0"/>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="0,0,16,0" VerticalAlignment="Center">
        <Button Content="Open BSP" Command="{Binding OpenBspCommand}" />
        <Button Content="Export .ent" Command="{Binding ExportEntCommand}" IsEnabled="{Binding HasResults}" />
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1" ColumnDefinitions="320,*">
      <!-- Left Panel: Parameters & Results -->
      <Border Grid.Column="0" Background="#252526" BorderBrush="#3e3e42" BorderThickness="0,0,1,0">
        <ScrollViewer>
          <StackPanel Spacing="12" Margin="16">
            <!-- Map Info -->
            <Border Background="#2d2d30" CornerRadius="4" Padding="12">
              <StackPanel Spacing="4">
                <TextBlock Text="Map Info" FontWeight="Bold" FontSize="14" Foreground="#cccccc"/>
                <TextBlock Text="{Binding MapName}" Foreground="#aaaaaa" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding MapFormat}" Foreground="#888888" FontSize="12"/>
                <TextBlock Text="{Binding SurfaceCount}" Foreground="#888888" FontSize="12"/>
              </StackPanel>
            </Border>

            <!-- Parameters -->
            <Border Background="#2d2d30" CornerRadius="4" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Parameters" FontWeight="Bold" FontSize="14" Foreground="#cccccc"/>
                <CheckBox Content="Half-Lambert" IsChecked="{Binding HalfLambert}" />
                <CheckBox Content="No Bounce Suppress" IsChecked="{Binding NoBounceSuppress}" />
                <CheckBox Content="No Vis" IsChecked="{Binding NoVis}" />
                <NumericUpDown Value="{Binding MaxLights}" Minimum="1" Maximum="1024" FormatString="0" Watermark="Max Lights"/>
                <NumericUpDown Value="{Binding MaxSamples}" Minimum="1000" Maximum="1000000" FormatString="0" Watermark="Max Samples"/>
                <NumericUpDown Value="{Binding Pivots}" Minimum="10" Maximum="5000" FormatString="0" Watermark="Pivots"/>
                <Button Content="Auto-Detect" Command="{Binding AutoDetectCommand}" HorizontalAlignment="Stretch"/>
              </StackPanel>
            </Border>

            <!-- Progress -->
            <Border Background="#2d2d30" CornerRadius="4" Padding="12" IsVisible="{Binding IsRunning}">
              <StackPanel Spacing="8">
                <TextBlock Text="Running..." FontWeight="Bold" Foreground="#cccccc"/>
                <ProgressBar Value="{Binding Progress}" Maximum="100" />
                <TextBlock Text="{Binding StatusText}" Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Results -->
            <Border Background="#2d2d30" CornerRadius="4" Padding="12" IsVisible="{Binding HasResults}">
              <StackPanel Spacing="8">
                <TextBlock Text="Results" FontWeight="Bold" FontSize="14" Foreground="#cccccc"/>
                <TextBlock Text="{Binding ResultSummary}" Foreground="#888888" FontSize="12"/>
                <Button Content="Run Estimator" Command="{Binding RunEstimatorCommand}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsRunning}"/>
              </StackPanel>
            </Border>
            <Button Content="Run Estimator" Command="{Binding RunEstimatorCommand}" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsRunning}" IsVisible="{Binding !HasResults}"/>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Right Panel: 3D Viewer -->
      <Border Grid.Column="1" Background="#1e1e1e">
        <Grid>
          <TextBlock Text="Drop a .bsp file here or click Open BSP" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#666666" FontSize="16" IsVisible="{Binding !HasMapLoaded}"/>
          <ContentControl Content="{Binding ViewerContent}" IsVisible="{Binding HasMapLoaded}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>
      </Border>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2" Background="#007acc" Height="24">
      <TextBlock Text="{Binding StatusMessage}" Foreground="White" VerticalAlignment="Center" Margin="16,0" FontSize="12"/>
    </Border>
  </Grid>
</Window>
